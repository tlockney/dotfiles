#!/bin/bash
# rpull - pull a file from the local machine to this remote machine via open-agent
# Usage: rpull ~/Downloads/image.png           # copies to current directory
#        rpull ~/Desktop/file.txt ~/dest/dir/  # copies to specific remote directory

set -euo pipefail

source "$(dirname "$0")/lib/open-agent.sh"

HOST_ALIAS="${OPEN_AGENT_HOST:-workmbp}"

usage() {
    cat <<'EOF'
Usage: rpull <local-path> [remote-dest]

Pull a file from the local Mac to this machine.
The local-path is a path on your personal Mac (e.g., ~/Downloads/file.txt).

Options:
  -h          Show this help

Arguments:
  local-path   Path on the local Mac
  remote-dest  Destination on this machine (default: current directory)

Examples:
  rpull ~/Downloads/image.png            # → ./image.png
  rpull ~/Desktop/notes.md ~/docs/       # → ~/docs/notes.md
EOF
    exit 0
}

oa_init
oa_require_sock

[[ "$1" == "-h" || "$1" == "--help" ]] && usage
[[ $# -eq 0 ]] && { echo "rpull: local path required. See rpull -h" >&2; exit 1; }

LOCAL_PATH="$1"
REMOTE_DEST="${2:-$(pwd)}"

# Resolve remote dest to absolute path
if [[ -e "$REMOTE_DEST" ]]; then
    REMOTE_DEST=$(realpath "$REMOTE_DEST")
elif [[ "$REMOTE_DEST" != /* ]]; then
    REMOTE_DEST="$(pwd)/$REMOTE_DEST"
fi

MSG="{\"action\":\"pull\",\"host\":$(oa_json_escape "$HOST_ALIAS"),\"remoteHome\":$(oa_json_escape "$HOME"),\"localPath\":$(oa_json_escape "$LOCAL_PATH"),\"remoteDest\":$(oa_json_escape "$REMOTE_DEST")}"

RESPONSE=$(oa_send "$MSG" 30) || {
    echo "${OA_SCRIPT_NAME}: failed to connect to agent" >&2
    exit 1
}

oa_check_response "$RESPONSE" || exit 1
REMOTE=$(oa_json_value "$RESPONSE" "remotePath")
echo "Pulled to: $REMOTE"
