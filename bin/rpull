#!/bin/bash
# rpull - pull a file from the local machine to this remote machine via open-agent
# Usage: rpull ~/Downloads/image.png           # copies to current directory
#        rpull ~/Desktop/file.txt ~/dest/dir/  # copies to specific remote directory

set -euo pipefail

SOCK="${OPEN_AGENT_SOCK:-/tmp/open-agent.sock}"
HOST_ALIAS="${OPEN_AGENT_HOST:-workmbp}"

usage() {
    cat <<'EOF'
Usage: rpull <local-path> [remote-dest]

Pull a file from the local Mac to this machine.
The local-path is a path on your personal Mac (e.g., ~/Downloads/file.txt).

Options:
  -h          Show this help

Arguments:
  local-path   Path on the local Mac
  remote-dest  Destination on this machine (default: current directory)

Examples:
  rpull ~/Downloads/image.png            # → ./image.png
  rpull ~/Desktop/notes.md ~/docs/       # → ~/docs/notes.md
EOF
    exit 0
}

if [[ ! -S "$SOCK" ]]; then
    echo "rpull: agent socket not found at $SOCK" >&2
    exit 1
fi

[[ "$1" == "-h" || "$1" == "--help" ]] && usage
[[ $# -eq 0 ]] && { echo "rpull: local path required. See rpull -h" >&2; exit 1; }

LOCAL_PATH="$1"
REMOTE_DEST="${2:-$(pwd)}"

# Resolve remote dest to absolute path
if [[ -e "$REMOTE_DEST" ]]; then
    REMOTE_DEST=$(realpath "$REMOTE_DEST")
elif [[ "$REMOTE_DEST" != /* ]]; then
    REMOTE_DEST="$(pwd)/$REMOTE_DEST"
fi

json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\t'/\\t}"
    printf '"%s"' "$s"
}

MSG="{\"action\":\"pull\",\"host\":$(json_escape "$HOST_ALIAS"),\"remoteHome\":$(json_escape "$HOME"),\"localPath\":$(json_escape "$LOCAL_PATH"),\"remoteDest\":$(json_escape "$REMOTE_DEST")}"

send_message() {
    if command -v socat &>/dev/null; then
        echo "$MSG" | socat -t30 - UNIX-CONNECT:"$SOCK" 2>/dev/null
    elif command -v nc &>/dev/null; then
        echo "$MSG" | nc -U -w30 "$SOCK" 2>/dev/null
    else
        echo "rpull: neither socat nor nc available" >&2
        return 1
    fi
}

RESPONSE=$(send_message) || {
    echo "rpull: failed to connect to agent" >&2
    exit 1
}

json_value() {
    echo "$1" | grep -o "\"$2\":\"[^\"]*\"" | head -1 | sed "s/\"$2\":\"//" | sed 's/"$//'
}

if echo "$RESPONSE" | grep -q '"ok":true'; then
    REMOTE=$(json_value "$RESPONSE" "remotePath")
    echo "Pulled to: $REMOTE"
else
    ERROR=$(json_value "$RESPONSE" "error")
    echo "rpull: ${ERROR:-unknown error}" >&2
    exit 1
fi
