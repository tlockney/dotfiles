#!/bin/bash
# rcopy - copy stdin to the local machine's clipboard via open-agent
# Usage: echo "text" | rcopy
#        cat file.txt | rcopy

set -euo pipefail

source "$(dirname "$0")/lib/open-agent.sh"
oa_init
oa_require_sock

# Read all of stdin
CONTENT=$(cat)

ESCAPED=$(oa_json_escape "$CONTENT")
MSG="{\"action\":\"copy\",\"content\":${ESCAPED}}"

RESPONSE=$(oa_send "$MSG") || {
    echo "${OA_SCRIPT_NAME}: failed to connect to agent" >&2
    exit 1
}

oa_check_response "$RESPONSE" || exit 1
