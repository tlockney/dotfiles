#!/usr/bin/env -S deno run --allow-read --allow-run --allow-env --allow-write

import { parseArgs } from "jsr:@std/cli@1/parse-args";
import { existsSync } from "jsr:@std/fs@1/exists";
import { dirname } from "jsr:@std/path@1/dirname";
import { join } from "jsr:@std/path@1/join";

// --- Configuration ---
const CAL_FILE = join(Deno.env.get("HOME")!, ".local/var/cal_agenda.json");
const VAULT_PATH = join(Deno.env.get("HOME")!, "Obsidian/Personal");
const MEETINGS_DIR = join(VAULT_PATH, "Active/Metron/Meetings");
const DAILY_CONFIG_FILE = join(VAULT_PATH, ".obsidian/daily-notes.json");
const DEFAULT_CALENDAR = "Work Calendar";
const SELF_NAME = "Thomas Lockney";

// --- Types ---
interface Attendee {
  email: string;
  name: string;
  role: string;
  status: string;
}

interface CalendarEvent {
  all_day: boolean;
  attendees?: Attendee[];
  calendar: string;
  end: string;
  location?: string;
  notes?: string;
  organizer?: Attendee;
  recurrence_rule?: {
    end_date: string;
    frequency: string;
    interval: number;
  };
  recurring?: boolean;
  start: string;
  status: string;
  title: string;
  uid: string;
}

interface CalendarData {
  calendars: string[];
  event_count: number;
  events: CalendarEvent[];
}

interface DailyNotesConfig {
  folder: string;
  format: string;
}

// --- Colors ---
const color = {
  red: (s: string) => `\x1b[0;31m${s}\x1b[0m`,
  green: (s: string) => `\x1b[0;32m${s}\x1b[0m`,
  blue: (s: string) => `\x1b[0;34m${s}\x1b[0m`,
  yellow: (s: string) => `\x1b[0;33m${s}\x1b[0m`,
  bold: (s: string) => `\x1b[1m${s}\x1b[0m`,
};

// --- Utilities ---

function loadCalendar(): CalendarData {
  if (!existsSync(CAL_FILE)) {
    throw new Error(`Calendar file not found: ${CAL_FILE}`);
  }
  return JSON.parse(Deno.readTextFileSync(CAL_FILE));
}

function formatTime(date: Date): string {
  return date.toLocaleTimeString("en-US", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });
}

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}

function toLocalDate(utcIso: string): Date {
  return new Date(utcIso);
}

// Days between two dates, counted in local calendar days (negative if `date` is before `today`).
function daysBetween(date: Date, today: Date): number {
  const a = Date.UTC(date.getFullYear(), date.getMonth(), date.getDate());
  const b = Date.UTC(today.getFullYear(), today.getMonth(), today.getDate());
  return Math.round((a - b) / 86_400_000);
}

// Render a day offset back into the query-string form the Alfred filter understands.
function offsetToken(n: number): string {
  if (n === 0) return "";
  return n > 0 ? `+${n}` : `${n}`;
}

function sanitizeFilename(title: string): string {
  return title
    .replace(/1:1/g, "1-1")
    .replace(/:/g, "")
    .replace(/\//g, " - ")
    .replace(/[\\<>"|?*]/g, "")
    .replace(/ {2,}/g, " ")
    .trim();
}

function detectMeetingType(
  title: string,
  inviteeCount: number,
): string | undefined {
  const lower = title.toLowerCase();
  if (/1:1|1-1|1on1|one-on-one/.test(lower)) return "1-1";
  if (inviteeCount <= 1) return "1-1";
  if (/standup|stand-up|daily scrum/.test(lower)) return "standup";
  if (/grooming|refinement/.test(lower)) return "grooming";
  if (/sprint.*planning|planning.*sprint/.test(lower)) return "planning";
  if (/retro(spective)?/.test(lower)) return "retro";
  return undefined;
}

function getInvitees(event: CalendarEvent): string[] {
  const names = new Set<string>();
  for (const a of event.attendees ?? []) {
    if (a.name && a.name !== SELF_NAME) names.add(a.name);
  }
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    names.add(event.organizer.name);
  }
  return [...names].sort();
}

function getEventsForDate(
  data: CalendarData,
  targetDate: string,
  calendars: string[],
): CalendarEvent[] {
  return data.events
    .filter((e) => calendars.includes(e.calendar) && !e.all_day)
    .filter((e) => formatDate(toLocalDate(e.start)) === targetDate)
    .sort((a, b) => a.start.localeCompare(b.start));
}

function getEventByUid(
  data: CalendarData,
  uid: string,
): CalendarEvent | undefined {
  return data.events.find((e) => e.uid === uid);
}

function isRecurring(data: CalendarData, event: CalendarEvent): boolean {
  if (event.recurring) return true;
  if (event.uid.includes("/RID=")) {
    const baseUid = event.uid.split("/RID=")[0];
    const parent = data.events.find((e) => e.uid === baseUid);
    return parent?.recurring === true;
  }
  return false;
}

function openInObsidian(filename: string): void {
  const noteName = filename.replace(/\.md$/, "");
  const encoded = encodeURIComponent(`Active/Metron/Meetings/${noteName}`);
  const cmd = new Deno.Command("open", {
    args: [`obsidian://open?vault=Personal&file=${encoded}`],
    stderr: "null",
  });
  cmd.outputSync();
}

// --- Daily note integration ---

function loadDailyNotesConfig(): DailyNotesConfig {
  if (!existsSync(DAILY_CONFIG_FILE)) {
    throw new Error(`Daily notes config not found: ${DAILY_CONFIG_FILE}`);
  }
  const raw = JSON.parse(Deno.readTextFileSync(DAILY_CONFIG_FILE));
  const folder = typeof raw.folder === "string" ? raw.folder : "";
  const format = typeof raw.format === "string" ? raw.format : "YYYY-MM-DD";
  return { folder, format };
}

function formatMomentDate(date: Date, format: string): string {
  const monthNames = [
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December",
  ];
  const tokens: Record<string, string> = {
    YYYY: String(date.getFullYear()),
    YY: String(date.getFullYear()).slice(-2),
    MMMM: monthNames[date.getMonth()],
    MMM: monthNames[date.getMonth()].slice(0, 3),
    MM: String(date.getMonth() + 1).padStart(2, "0"),
    M: String(date.getMonth() + 1),
    DD: String(date.getDate()).padStart(2, "0"),
    D: String(date.getDate()),
  };
  return format.replace(/YYYY|YY|MMMM|MMM|MM|M|DD|D/g, (t) => tokens[t]);
}

function dailyNoteRelativePath(date: Date, cfg: DailyNotesConfig): string {
  return join(cfg.folder, formatMomentDate(date, cfg.format) + ".md");
}

function dailyNoteTemplate(date: Date, cfg: DailyNotesConfig): string {
  const yesterday = new Date(date);
  yesterday.setDate(date.getDate() - 1);
  const tomorrow = new Date(date);
  tomorrow.setDate(date.getDate() + 1);
  const title = formatMomentDate(date, "YYYY-MM-DD");
  const yLink = join(cfg.folder, formatMomentDate(yesterday, cfg.format));
  const tLink = join(cfg.folder, formatMomentDate(tomorrow, cfg.format));
  const yTitle = formatMomentDate(yesterday, "YYYY-MM-DD");
  const tTitle = formatMomentDate(tomorrow, "YYYY-MM-DD");
  return `# [[${title}]]\n\n<< [[${yLink}|${yTitle}]] | [[${tLink}|${tTitle}]] >>\n# Journal\n`;
}

async function ensureDailyNote(
  date: Date,
  absolutePath: string,
  cfg: DailyNotesConfig,
): Promise<void> {
  if (existsSync(absolutePath)) return;
  await Deno.mkdir(dirname(absolutePath), { recursive: true });
  Deno.writeTextFileSync(absolutePath, dailyNoteTemplate(date, cfg));
}

function appendMeetingToJournal(opts: {
  dailyNotePath: string;
  meetingLink: string;
  startTime: string;
  endTime: string;
}): "added" | "skipped" {
  const content = Deno.readTextFileSync(opts.dailyNotePath);
  const linkMarker = `[[${opts.meetingLink}]]`;
  if (content.includes(linkMarker)) return "skipped";

  const entry = `- ${opts.startTime}–${opts.endTime} ${linkMarker}`;
  const journalMatch = content.match(/(^|\n)# Journal(\r?\n|$)/);
  if (!journalMatch || journalMatch.index === undefined) {
    throw new Error(`No "# Journal" heading found in ${opts.dailyNotePath}`);
  }
  const journalIdx = journalMatch.index + (journalMatch[1] ? 1 : 0);

  const meetingsMatch = content.match(/(^|\n)# Meetings(\r?\n|$)/);
  let updated: string;
  if (!meetingsMatch) {
    const before = content.slice(0, journalIdx);
    const after = content.slice(journalIdx);
    updated = `${before}# Meetings\n\n${entry}\n\n${after}`;
  } else {
    const before = content.slice(0, journalIdx).trimEnd();
    const after = content.slice(journalIdx);
    updated = `${before}\n${entry}\n\n${after}`;
  }

  Deno.writeTextFileSync(opts.dailyNotePath, updated);
  return "added";
}

async function linkMeetingToDailyNote(opts: {
  date: Date;
  meetingLink: string;
  startTime: string;
  endTime: string;
}): Promise<void> {
  try {
    const cfg = loadDailyNotesConfig();
    const relPath = dailyNoteRelativePath(opts.date, cfg);
    const absPath = join(VAULT_PATH, relPath);
    await ensureDailyNote(opts.date, absPath, cfg);
    const result = appendMeetingToJournal({
      dailyNotePath: absPath,
      meetingLink: opts.meetingLink,
      startTime: opts.startTime,
      endTime: opts.endTime,
    });
    if (result === "added") {
      console.log(color.green(`Linked in daily note: ${relPath}`));
    }
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    console.error(color.yellow(`Warning: could not update daily note: ${msg}`));
  }
}

// --- Commands ---

function cmdList(
  targetDate: string,
  jsonMode: boolean,
  query: string,
  calendars: string[],
): void {
  const data = loadCalendar();
  const events = getEventsForDate(data, targetDate, calendars);

  if (events.length === 0) {
    if (jsonMode) {
      console.log(JSON.stringify({
        items: [{
          title: "No meetings",
          subtitle: `No meetings found for ${targetDate}`,
          valid: false,
        }],
      }));
    } else {
      console.log(color.blue(`No meetings found for ${targetDate}`));
    }
    return;
  }

  if (jsonMode) {
    const items = events
      .filter((event) => {
        if (!query) return true;
        return event.title.toLowerCase().includes(query.toLowerCase());
      })
      .map((event) => {
        const start = toLocalDate(event.start);
        const end = toLocalDate(event.end);
        const inviteeCount = getInvitees(event).length;
        return {
          uid: event.uid,
          title: event.title,
          subtitle: `${formatTime(start)} - ${
            formatTime(end)
          } • ${inviteeCount} invitees`,
          arg: event.uid,
          autocomplete: event.title,
        };
      });
    console.log(JSON.stringify({ items }));
  } else {
    console.log(color.blue(`Meetings for ${targetDate}:`));
    console.log();
    for (const event of events) {
      const start = toLocalDate(event.start);
      const end = toLocalDate(event.end);
      const inviteeCount = getInvitees(event).length;
      const label = inviteeCount === 1
        ? "1 invitee"
        : `${inviteeCount} invitees`;
      console.log(
        `  ${formatTime(start)} - ${
          formatTime(end)
        }  ${event.title} (${label})`,
      );
    }
  }
}

// Parse an Alfred query into a target date + meeting filter.
// Recognized leading tokens: "+N", "-N", or "YYYY-MM-DD". Anything else is
// treated entirely as a filter against today.
function parseAlfredQuery(
  query: string,
  today: Date,
): { date: Date; filter: string } {
  const trimmed = query.trim();
  if (!trimmed) return { date: today, filter: "" };

  const match = trimmed.match(/^(\S+)(?:\s+(.*))?$/);
  if (!match) return { date: today, filter: "" };
  const [, head, rest = ""] = match;
  const filterRest = rest.trim();

  const offsetMatch = head.match(/^([+-])(\d+)$/);
  if (offsetMatch) {
    const sign = offsetMatch[1] === "-" ? -1 : 1;
    const n = parseInt(offsetMatch[2], 10);
    const d = new Date(today);
    d.setDate(today.getDate() + sign * n);
    return { date: d, filter: filterRest };
  }

  const absMatch = head.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (absMatch) {
    const [, y, m, day] = absMatch;
    const d = new Date(Number(y), Number(m) - 1, Number(day));
    return { date: d, filter: filterRest };
  }

  return { date: today, filter: trimmed };
}

function cmdListAlfred(rawQuery: string, calendars: string[]): void {
  const today = new Date();
  const { date, filter } = parseAlfredQuery(rawQuery, today);
  const targetDate = formatDate(date);
  const offset = daysBetween(date, today);

  const data = loadCalendar();
  const events = getEventsForDate(data, targetDate, calendars);

  const prevDate = new Date(date);
  prevDate.setDate(date.getDate() - 1);
  const nextDate = new Date(date);
  nextDate.setDate(date.getDate() + 1);

  const navAutocomplete = (newOffset: number): string => {
    const tok = offsetToken(newOffset);
    if (!filter) return tok;
    return tok ? `${tok} ${filter}` : filter;
  };

  const navLabel = (d: Date): string => {
    const day = d.toLocaleDateString("en-US", { weekday: "short" });
    return `${day} ${formatDate(d)}`;
  };

  const items: Array<Record<string, unknown>> = [];

  items.push({
    title: `← Previous day  (${navLabel(prevDate)})`,
    subtitle: "Tab to navigate",
    valid: false,
    autocomplete: navAutocomplete(offset - 1),
  });

  if (offset !== 0) {
    items.push({
      title: `↩ Today  (${navLabel(today)})`,
      subtitle: "Tab to navigate",
      valid: false,
      autocomplete: navAutocomplete(0),
    });
  }

  items.push({
    title: `→ Next day  (${navLabel(nextDate)})`,
    subtitle: "Tab to navigate",
    valid: false,
    autocomplete: navAutocomplete(offset + 1),
  });

  const filtered = filter
    ? events.filter((e) => e.title.toLowerCase().includes(filter.toLowerCase()))
    : events;

  if (filtered.length === 0) {
    items.push({
      title: "No meetings",
      subtitle: filter
        ? `No meetings on ${targetDate} matching "${filter}"`
        : `No meetings on ${targetDate}`,
      valid: false,
    });
  } else {
    for (const event of filtered) {
      const start = toLocalDate(event.start);
      const end = toLocalDate(event.end);
      const inviteeCount = getInvitees(event).length;
      items.push({
        uid: event.uid,
        title: event.title,
        subtitle: `${formatTime(start)} - ${
          formatTime(end)
        } • ${inviteeCount} invitees`,
        arg: event.uid,
        autocomplete: event.title,
      });
    }
  }

  console.log(JSON.stringify({ items }));
}

function cmdCalendars(): void {
  const data = loadCalendar();
  const counts: Record<string, number> = {};
  for (const e of data.events) {
    counts[e.calendar] = (counts[e.calendar] ?? 0) + 1;
  }
  const list = [...new Set(data.calendars)].sort();
  if (list.length === 0) {
    console.log(color.blue("No calendars found in agenda export."));
    return;
  }
  console.log(color.blue("Available calendars:"));
  console.log();
  const maxLen = Math.max(...list.map((c) => c.length));
  for (const cal of list) {
    const n = counts[cal] ?? 0;
    const pad = " ".repeat(maxLen - cal.length);
    const label = n === 1 ? "event" : "events";
    console.log(`  ${cal}${pad}  (${n} ${label})`);
  }
}

function cmdPreview(uid: string): void {
  const data = loadCalendar();
  const event = getEventByUid(data, uid);
  if (!event) {
    console.log("Event not found");
    return;
  }

  const start = toLocalDate(event.start);
  const end = toLocalDate(event.end);
  const localDate = formatDate(start);
  const invitees = getInvitees(event);
  const meetingType = detectMeetingType(event.title, invitees.length);
  const recurring = isRecurring(data, event);

  console.log(color.bold(event.title));
  console.log();
  console.log(`  Date:       ${localDate}`);
  console.log(`  Time:       ${formatTime(start)} - ${formatTime(end)}`);
  if (meetingType) console.log(`  Type:       ${meetingType}`);
  if (recurring) console.log(`  Recurring:  yes`);
  if (event.location) console.log(`  Location:   ${event.location}`);
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    console.log(`  Organizer:  ${event.organizer.name}`);
  }
  console.log();
  console.log(color.bold(`Invitees (${invitees.length}):`));
  for (const name of invitees) {
    console.log(`  - ${name}`);
  }

  // Check if note already exists
  const safeTitle = sanitizeFilename(event.title);
  const filename = `${safeTitle} - ${localDate}.md`;
  const filepath = join(MEETINGS_DIR, filename);
  if (existsSync(filepath)) {
    console.log();
    console.log(color.yellow("Note already exists"));
  }
}

function cmdFzfData(datefile: string): void {
  const targetDate = Deno.readTextFileSync(datefile).trim();
  const data = loadCalendar();
  const calendars = (Deno.env.get("MTG_CALENDARS") ?? DEFAULT_CALENDAR)
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);
  const events = getEventsForDate(data, targetDate, calendars);

  for (const event of events) {
    const start = toLocalDate(event.start);
    const end = toLocalDate(event.end);
    const invitees = getInvitees(event);
    const label = invitees.length === 1
      ? "1 invitee"
      : `${invitees.length} invitees`;
    console.log(
      `${event.uid}\t${formatTime(start)} - ${
        formatTime(end)
      }  ${event.title} (${label})`,
    );
  }
}

function cmdFzfNav(direction: string, datefile: string): void {
  const currentDate = Deno.readTextFileSync(datefile).trim();
  const date = new Date(currentDate + "T12:00:00");
  date.setDate(date.getDate() + (direction === "prev" ? -1 : 1));
  Deno.writeTextFileSync(datefile, formatDate(date));
}

function cmdFzfHeader(datefile: string): void {
  const currentDate = Deno.readTextFileSync(datefile).trim();
  const date = new Date(currentDate + "T12:00:00");
  const dayName = date.toLocaleDateString("en-US", { weekday: "long" });
  console.log(
    `${dayName} ${currentDate}  |  ← prev day  ·  next day →`,
  );
}

async function cmdCreate(
  targetDate: string,
  eventUid: string,
  jsonMode: boolean,
  noJournal: boolean,
  calendars: string[],
): Promise<void> {
  const data = loadCalendar();
  let event: CalendarEvent | undefined;

  if (eventUid) {
    event = getEventByUid(data, eventUid);
    if (!event) {
      if (jsonMode) {
        console.log(JSON.stringify({
          items: [{
            title: "Error",
            subtitle: `No event found with UID: ${eventUid}`,
            valid: false,
          }],
        }));
        Deno.exit(0);
      }
      console.error(color.red(`Error: No event found with UID: ${eventUid}`));
      Deno.exit(1);
    }
  } else {
    // Interactive selection via fzf with day navigation
    const scriptPath = new URL(import.meta.url).pathname;
    const datefile = await Deno.makeTempFile();

    try {
      Deno.writeTextFileSync(datefile, targetDate);

      // Generate initial data directly (no subprocess needed for initial load)
      const data2 = loadCalendar();
      const initialEvents = getEventsForDate(
        data2,
        Deno.readTextFileSync(datefile).trim(),
        calendars,
      );
      const fzfInput = initialEvents
        .map((e) => {
          const s = toLocalDate(e.start);
          const en = toLocalDate(e.end);
          const inv = getInvitees(e);
          const lbl = inv.length === 1 ? "1 invitee" : `${inv.length} invitees`;
          return `${e.uid}\t${formatTime(s)} - ${
            formatTime(en)
          }  ${e.title} (${lbl})`;
        })
        .join("\n");

      const currentDate = Deno.readTextFileSync(datefile).trim();
      const headerDate = new Date(currentDate + "T12:00:00");
      const dayName = headerDate.toLocaleDateString("en-US", {
        weekday: "long",
      });
      const initialHeader =
        `${dayName} ${currentDate}  |  ← prev day  ·  next day →`;

      const bindPrev =
        `left:execute-silent(${scriptPath} _fzf-nav prev ${datefile})+reload(${scriptPath} _fzf-data ${datefile})+transform-header(${scriptPath} _fzf-header ${datefile})`;
      const bindNext =
        `right:execute-silent(${scriptPath} _fzf-nav next ${datefile})+reload(${scriptPath} _fzf-data ${datefile})+transform-header(${scriptPath} _fzf-header ${datefile})`;

      const fzfProc = new Deno.Command("fzf", {
        args: [
          "--height=80%",
          "--layout=reverse",
          "--border",
          "--delimiter=\t",
          "--with-nth=2",
          `--preview=${scriptPath} _preview {1}`,
          "--preview-window=right:50%:wrap",
          `--bind=${bindPrev}`,
          `--bind=${bindNext}`,
          "--prompt=Select meeting: ",
          `--header=${initialHeader}`,
        ],
        env: { MTG_CALENDARS: calendars.join(",") },
        stdin: "piped",
        stdout: "piped",
        stderr: "inherit",
      });

      const child = fzfProc.spawn();
      const writer = child.stdin.getWriter();
      await writer.write(new TextEncoder().encode(fzfInput));
      await writer.close();
      const output = await child.output();
      const selected = new TextDecoder().decode(output.stdout).trim();

      if (!selected) {
        console.log("Cancelled.");
        Deno.exit(0);
      }

      const selectedUid = selected.split("\t")[0];
      event = getEventByUid(data, selectedUid);
      if (!event) {
        console.error(color.red("Error: Failed to find selected meeting"));
        Deno.exit(1);
      }
    } finally {
      try {
        Deno.removeSync(datefile);
      } catch { /* ignore */ }
    }
  }

  // Extract event details
  const start = toLocalDate(event.start);
  const end = toLocalDate(event.end);
  const localDate = formatDate(start);
  const startTime = formatTime(start);
  const endTime = formatTime(end);
  const invitees = getInvitees(event);
  const meetingType = detectMeetingType(event.title, invitees.length);
  const recurring = isRecurring(data, event);
  const series = recurring ? event.title : undefined;

  // Build file path
  const safeTitle = sanitizeFilename(event.title);
  const filename = `${safeTitle} - ${localDate}.md`;
  const filepath = join(MEETINGS_DIR, filename);

  const meetingLink = `${safeTitle} - ${localDate}`;

  // Check for existing note
  if (existsSync(filepath)) {
    if (!noJournal) {
      await linkMeetingToDailyNote({
        date: start,
        meetingLink,
        startTime,
        endTime,
      });
    }
    if (jsonMode) {
      console.error(color.yellow(`Note already exists: ${filename}`));
      return;
    }
    console.error(color.yellow(`Note already exists: ${filename}`));
    if (Deno.stdin.isTerminal()) {
      const buf = new Uint8Array(10);
      Deno.stdout.writeSync(
        new TextEncoder().encode("Open existing note? [Y/n] "),
      );
      const n = Deno.stdin.readSync(buf);
      const answer = n
        ? new TextDecoder().decode(buf.subarray(0, n)).trim()
        : "Y";
      if (/^[Yy]?$/.test(answer)) {
        openInObsidian(filename);
      }
    }
    return;
  }

  // Ensure directory exists
  await Deno.mkdir(MEETINGS_DIR, { recursive: true });

  // Build note content
  const inviteeYaml = invitees.map((name) => `  - ${name}`).join("\n");
  const inviteeLinks = invitees.map((name) => `- [[${name}]]`).join("\n");

  let frontmatter = `---
tags:
  - meeting
date: ${localDate}
start-time: "${startTime}"
end-time: "${endTime}"`;

  if (series) frontmatter += `\nseries: "${series}"`;
  if (meetingType) frontmatter += `\nmeeting-type: ${meetingType}`;
  frontmatter += `\ninvitees:\n${inviteeYaml}`;
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    frontmatter += `\norganizer: ${event.organizer.name}`;
  }
  if (event.location) frontmatter += `\nlocation: "${event.location}"`;
  frontmatter += `\ncalendar: ${event.calendar}`;
  frontmatter += `\n---`;

  const noteContent = `${frontmatter}

# ${event.title}

## Attendees
${inviteeLinks}

## Notes

## Summary

## Action Items
- [ ] `;

  Deno.writeTextFileSync(filepath, noteContent);
  console.log(color.green(`Created: ${filename}`));
  if (!noJournal) {
    await linkMeetingToDailyNote({
      date: start,
      meetingLink,
      startTime,
      endTime,
    });
  }
  openInObsidian(filename);
}

// --- Help ---

function showHelp(): void {
  const name = "mtg";
  console.log(`Usage: ${name} [command] [options]

Commands:
    list      (l)     List meetings for today (or specified date)
    calendars (cals)  List calendars available in the agenda export
    create    (c)     Create a meeting note
    help              Show this help

    If no command is given, interactively select a meeting and create a note.

Options:
    --date DATE   Target date in YYYY-MM-DD format (default: today)
    --json        Output as Alfred-compatible JSON (list command only)
    --alfred      Alfred mode for list: parses -q as "[+N|-N|YYYY-MM-DD] filter"
                  and prepends day-navigation items (implies --json)
    -q QUERY      Filter meetings by query (with --json)
    --uid UID     Specify meeting by calendar UID (create command)
    --calendar C  Calendar(s) to filter — comma-separated for multiple
                  (default: "${DEFAULT_CALENDAR}")
    --no-journal  Skip linking the meeting from the daily note (create command)
    --help        Show this help

Examples:
    ${name}                           # Interactive: pick meeting & create note
    ${name} l                         # List today's meetings
    ${name} list --date 2026-03-01    # List meetings for a specific date
    ${name} list --json               # JSON output for Alfred
    ${name} list --json -q standup    # Alfred JSON filtered by query
    ${name} c                         # Interactively create a meeting note
    ${name} create --uid ABC-123      # Create note for a specific meeting UID
    ${name} l --calendar "Personal Calendar"
    ${name} l --calendar "Work Calendar,Personal Calendar"`);
}

// --- Main ---

const args = Deno.args;
const command = args[0] ?? "";

// Internal subcommands (called by fzf)
if (command === "_preview") {
  cmdPreview(args[1]);
  Deno.exit(0);
}
if (command === "_fzf-data") {
  cmdFzfData(args[1]);
  Deno.exit(0);
}
if (command === "_fzf-nav") {
  cmdFzfNav(args[1], args[2]);
  Deno.exit(0);
}
if (command === "_fzf-header") {
  cmdFzfHeader(args[1]);
  Deno.exit(0);
}

// Parse remaining args after the command
const isCommand = [
  "l",
  "list",
  "c",
  "create",
  "calendars",
  "cals",
  "help",
  "--help",
].includes(command);
const restArgs = isCommand ? args.slice(1) : args;
const parsed = parseArgs(restArgs, {
  string: ["date", "q", "uid", "calendar"],
  boolean: ["json", "help", "no-journal", "alfred"],
  default: {
    date: formatDate(new Date()),
    json: false,
    q: "",
    uid: "",
    "no-journal": false,
    alfred: false,
    calendar: DEFAULT_CALENDAR,
  },
});

if (parsed.help || command === "help" || command === "--help") {
  showHelp();
  Deno.exit(0);
}

const targetDate = parsed.date as string;
const jsonMode = parsed.json as boolean;
const query = parsed.q as string;
const eventUid = parsed.uid as string;
const noJournal = parsed["no-journal"] as boolean;
const alfredMode = parsed.alfred as boolean;
const calendars = (parsed.calendar as string)
  .split(",")
  .map((s) => s.trim())
  .filter(Boolean);

switch (command) {
  case "l":
  case "list":
    if (alfredMode) {
      cmdListAlfred(query, calendars);
    } else {
      cmdList(targetDate, jsonMode, query, calendars);
    }
    break;
  case "calendars":
  case "cals":
    cmdCalendars();
    break;
  case "c":
  case "create":
    await cmdCreate(targetDate, eventUid, jsonMode, noJournal, calendars);
    break;
  default:
    // No command or unknown flag — default to create
    if (command && !command.startsWith("-")) {
      console.error(
        color.red(
          `Error: Unknown command: ${command}. Use 'mtg help' for usage.`,
        ),
      );
      Deno.exit(1);
    }
    await cmdCreate(targetDate, eventUid, jsonMode, noJournal, calendars);
    break;
}
