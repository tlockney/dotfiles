#!/usr/bin/env bash
# tc - Create or attach to a tmux session named after the current directory.
# Usage: tc [session-name]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: tc [session-name]"
    echo ""
    echo "Create or attach to a tmux session."
    echo "Defaults to the current directory name if no session name is given."
    exit 0
fi

PATH=/opt/homebrew/bin:$PATH

require_command "tmux" "brew install tmux"

SESSION_NAME="${1:-$(basename "$(pwd)")}"

# If already inside a tmux session, handle session switching
if [[ -n "${TMUX:-}" ]]; then
    CURRENT_SESSION="$(tmux display-message -p '#S')"

    if [[ "$CURRENT_SESSION" == "$SESSION_NAME" ]]; then
        info "Already in session '$SESSION_NAME'."
        exit 0
    fi

    read -rp "Switch from session '$CURRENT_SESSION' to '$SESSION_NAME'? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
            info "Creating session '$SESSION_NAME'..."
            tmux new-session -d -s "$SESSION_NAME"
        fi
        info "Switching to session '$SESSION_NAME'..."
        tmux switch-client -t "$SESSION_NAME"
    else
        info "Staying in session '$CURRENT_SESSION'."
    fi
    exit 0
fi

# Outside tmux: attach or create
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    info "Attaching to session '$SESSION_NAME'..."
    tmux attach-session -t "$SESSION_NAME"
else
    info "Creating session '$SESSION_NAME'..."
    tmux new-session -s "$SESSION_NAME"
fi
