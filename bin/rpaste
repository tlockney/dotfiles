#!/bin/bash
# rpaste - paste from the local machine's clipboard via open-agent
# Usage: rpaste
#        rpaste | vim -

set -euo pipefail

source "$(dirname "$0")/lib/open-agent.sh"
oa_init
oa_require_sock

RESPONSE=$(oa_send '{"action":"paste"}') || {
    echo "${OA_SCRIPT_NAME}: failed to connect to agent" >&2
    exit 1
}

if oa_check_response "$RESPONSE"; then
    # Extract the content field — handles embedded \n, \t etc. from JSON
    echo "$RESPONSE" | python3 -c 'import json,sys; d=json.load(sys.stdin); sys.stdout.write(d.get("content",""))'
else
    exit 1
fi
