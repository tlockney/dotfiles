#!/usr/bin/env -S deno run --allow-read --allow-run --allow-env --allow-write

import { parseArgs } from "jsr:@std/cli@1/parse-args";
import { existsSync } from "jsr:@std/fs@1/exists";
import { join } from "jsr:@std/path@1/join";

// --- Configuration ---
const CAL_FILE = join(Deno.env.get("HOME")!, ".local/var/cal_agenda.json");
const VAULT_PATH = join(Deno.env.get("HOME")!, "Obsidian/Personal");
const MEETINGS_DIR = join(VAULT_PATH, "Active/Metron/Meetings");
const CALENDAR_FILTER = "Work Calendar";
const SELF_NAME = "Thomas Lockney";

// --- Types ---
interface Attendee {
  email: string;
  name: string;
  role: string;
  status: string;
}

interface CalendarEvent {
  all_day: boolean;
  attendees?: Attendee[];
  calendar: string;
  end: string;
  location?: string;
  notes?: string;
  organizer?: Attendee;
  recurrence_rule?: {
    end_date: string;
    frequency: string;
    interval: number;
  };
  recurring?: boolean;
  start: string;
  status: string;
  title: string;
  uid: string;
}

interface CalendarData {
  calendars: string[];
  event_count: number;
  events: CalendarEvent[];
}

// --- Colors ---
const color = {
  red: (s: string) => `\x1b[0;31m${s}\x1b[0m`,
  green: (s: string) => `\x1b[0;32m${s}\x1b[0m`,
  blue: (s: string) => `\x1b[0;34m${s}\x1b[0m`,
  yellow: (s: string) => `\x1b[0;33m${s}\x1b[0m`,
  bold: (s: string) => `\x1b[1m${s}\x1b[0m`,
};

// --- Utilities ---

function loadCalendar(): CalendarData {
  if (!existsSync(CAL_FILE)) {
    throw new Error(`Calendar file not found: ${CAL_FILE}`);
  }
  return JSON.parse(Deno.readTextFileSync(CAL_FILE));
}

function formatTime(date: Date): string {
  return date.toLocaleTimeString("en-US", {
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  });
}

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}

function toLocalDate(utcIso: string): Date {
  return new Date(utcIso);
}

function sanitizeFilename(title: string): string {
  return title
    .replace(/1:1/g, "1-1")
    .replace(/:/g, "")
    .replace(/\//g, " - ")
    .replace(/[\\<>"|?*]/g, "")
    .replace(/ {2,}/g, " ")
    .trim();
}

function detectMeetingType(
  title: string,
  inviteeCount: number,
): string | undefined {
  const lower = title.toLowerCase();
  if (/1:1|1-1|1on1|one-on-one/.test(lower)) return "1-1";
  if (inviteeCount <= 1) return "1-1";
  if (/standup|stand-up|daily scrum/.test(lower)) return "standup";
  if (/grooming|refinement/.test(lower)) return "grooming";
  if (/sprint.*planning|planning.*sprint/.test(lower)) return "planning";
  if (/retro(spective)?/.test(lower)) return "retro";
  return undefined;
}

function getInvitees(event: CalendarEvent): string[] {
  const names = new Set<string>();
  for (const a of event.attendees ?? []) {
    if (a.name && a.name !== SELF_NAME) names.add(a.name);
  }
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    names.add(event.organizer.name);
  }
  return [...names].sort();
}

function getEventsForDate(
  data: CalendarData,
  targetDate: string,
): CalendarEvent[] {
  return data.events
    .filter((e) => e.calendar === CALENDAR_FILTER && !e.all_day)
    .filter((e) => formatDate(toLocalDate(e.start)) === targetDate)
    .sort((a, b) => a.start.localeCompare(b.start));
}

function getEventByUid(
  data: CalendarData,
  uid: string,
): CalendarEvent | undefined {
  return data.events.find((e) => e.uid === uid);
}

function isRecurring(data: CalendarData, event: CalendarEvent): boolean {
  if (event.recurring) return true;
  if (event.uid.includes("/RID=")) {
    const baseUid = event.uid.split("/RID=")[0];
    const parent = data.events.find((e) => e.uid === baseUid);
    return parent?.recurring === true;
  }
  return false;
}

function openInObsidian(filename: string): void {
  const noteName = filename.replace(/\.md$/, "");
  const encoded = encodeURIComponent(`Active/Metron/Meetings/${noteName}`);
  const cmd = new Deno.Command("open", {
    args: [`obsidian://open?vault=Personal&file=${encoded}`],
    stderr: "null",
  });
  cmd.outputSync();
}

// --- Commands ---

function cmdList(
  targetDate: string,
  jsonMode: boolean,
  query: string,
): void {
  const data = loadCalendar();
  const events = getEventsForDate(data, targetDate);

  if (events.length === 0) {
    if (jsonMode) {
      console.log(JSON.stringify({
        items: [{
          title: "No meetings",
          subtitle: `No meetings found for ${targetDate}`,
          valid: false,
        }],
      }));
    } else {
      console.log(color.blue(`No meetings found for ${targetDate}`));
    }
    return;
  }

  if (jsonMode) {
    const items = events
      .filter((event) => {
        if (!query) return true;
        return event.title.toLowerCase().includes(query.toLowerCase());
      })
      .map((event) => {
        const start = toLocalDate(event.start);
        const end = toLocalDate(event.end);
        const inviteeCount = getInvitees(event).length;
        return {
          uid: event.uid,
          title: event.title,
          subtitle: `${formatTime(start)} - ${
            formatTime(end)
          } • ${inviteeCount} invitees`,
          arg: event.uid,
          autocomplete: event.title,
        };
      });
    console.log(JSON.stringify({ items }));
  } else {
    console.log(color.blue(`Meetings for ${targetDate}:`));
    console.log();
    for (const event of events) {
      const start = toLocalDate(event.start);
      const end = toLocalDate(event.end);
      const inviteeCount = getInvitees(event).length;
      const label = inviteeCount === 1
        ? "1 invitee"
        : `${inviteeCount} invitees`;
      console.log(
        `  ${formatTime(start)} - ${
          formatTime(end)
        }  ${event.title} (${label})`,
      );
    }
  }
}

function cmdPreview(uid: string): void {
  const data = loadCalendar();
  const event = getEventByUid(data, uid);
  if (!event) {
    console.log("Event not found");
    return;
  }

  const start = toLocalDate(event.start);
  const end = toLocalDate(event.end);
  const localDate = formatDate(start);
  const invitees = getInvitees(event);
  const meetingType = detectMeetingType(event.title, invitees.length);
  const recurring = isRecurring(data, event);

  console.log(color.bold(event.title));
  console.log();
  console.log(`  Date:       ${localDate}`);
  console.log(`  Time:       ${formatTime(start)} - ${formatTime(end)}`);
  if (meetingType) console.log(`  Type:       ${meetingType}`);
  if (recurring) console.log(`  Recurring:  yes`);
  if (event.location) console.log(`  Location:   ${event.location}`);
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    console.log(`  Organizer:  ${event.organizer.name}`);
  }
  console.log();
  console.log(color.bold(`Invitees (${invitees.length}):`));
  for (const name of invitees) {
    console.log(`  - ${name}`);
  }

  // Check if note already exists
  const safeTitle = sanitizeFilename(event.title);
  const filename = `${safeTitle} - ${localDate}.md`;
  const filepath = join(MEETINGS_DIR, filename);
  if (existsSync(filepath)) {
    console.log();
    console.log(color.yellow("Note already exists"));
  }
}

function cmdFzfData(datefile: string): void {
  const targetDate = Deno.readTextFileSync(datefile).trim();
  const data = loadCalendar();
  const events = getEventsForDate(data, targetDate);

  for (const event of events) {
    const start = toLocalDate(event.start);
    const end = toLocalDate(event.end);
    const invitees = getInvitees(event);
    const label = invitees.length === 1
      ? "1 invitee"
      : `${invitees.length} invitees`;
    console.log(
      `${event.uid}\t${formatTime(start)} - ${
        formatTime(end)
      }  ${event.title} (${label})`,
    );
  }
}

function cmdFzfNav(direction: string, datefile: string): void {
  const currentDate = Deno.readTextFileSync(datefile).trim();
  const date = new Date(currentDate + "T12:00:00");
  date.setDate(date.getDate() + (direction === "prev" ? -1 : 1));
  Deno.writeTextFileSync(datefile, formatDate(date));
}

function cmdFzfHeader(datefile: string): void {
  const currentDate = Deno.readTextFileSync(datefile).trim();
  const date = new Date(currentDate + "T12:00:00");
  const dayName = date.toLocaleDateString("en-US", { weekday: "long" });
  console.log(
    `${dayName} ${currentDate}  |  ← prev day  ·  next day →`,
  );
}

async function cmdCreate(
  targetDate: string,
  eventUid: string,
  jsonMode: boolean,
): Promise<void> {
  const data = loadCalendar();
  let event: CalendarEvent | undefined;

  if (eventUid) {
    event = getEventByUid(data, eventUid);
    if (!event) {
      if (jsonMode) {
        console.log(JSON.stringify({
          items: [{
            title: "Error",
            subtitle: `No event found with UID: ${eventUid}`,
            valid: false,
          }],
        }));
        Deno.exit(0);
      }
      console.error(color.red(`Error: No event found with UID: ${eventUid}`));
      Deno.exit(1);
    }
  } else {
    // Interactive selection via fzf with day navigation
    const scriptPath = new URL(import.meta.url).pathname;
    const datefile = await Deno.makeTempFile();

    try {
      Deno.writeTextFileSync(datefile, targetDate);

      // Generate initial data directly (no subprocess needed for initial load)
      const data2 = loadCalendar();
      const initialEvents = getEventsForDate(
        data2,
        Deno.readTextFileSync(datefile).trim(),
      );
      const fzfInput = initialEvents
        .map((e) => {
          const s = toLocalDate(e.start);
          const en = toLocalDate(e.end);
          const inv = getInvitees(e);
          const lbl = inv.length === 1 ? "1 invitee" : `${inv.length} invitees`;
          return `${e.uid}\t${formatTime(s)} - ${
            formatTime(en)
          }  ${e.title} (${lbl})`;
        })
        .join("\n");

      const currentDate = Deno.readTextFileSync(datefile).trim();
      const headerDate = new Date(currentDate + "T12:00:00");
      const dayName = headerDate.toLocaleDateString("en-US", {
        weekday: "long",
      });
      const initialHeader =
        `${dayName} ${currentDate}  |  ← prev day  ·  next day →`;

      const bindPrev =
        `left:execute-silent(${scriptPath} _fzf-nav prev ${datefile})+reload(${scriptPath} _fzf-data ${datefile})+transform-header(${scriptPath} _fzf-header ${datefile})`;
      const bindNext =
        `right:execute-silent(${scriptPath} _fzf-nav next ${datefile})+reload(${scriptPath} _fzf-data ${datefile})+transform-header(${scriptPath} _fzf-header ${datefile})`;

      const fzfProc = new Deno.Command("fzf", {
        args: [
          "--height=80%",
          "--layout=reverse",
          "--border",
          "--delimiter=\t",
          "--with-nth=2",
          `--preview=${scriptPath} _preview {1}`,
          "--preview-window=right:50%:wrap",
          `--bind=${bindPrev}`,
          `--bind=${bindNext}`,
          "--prompt=Select meeting: ",
          `--header=${initialHeader}`,
        ],
        stdin: "piped",
        stdout: "piped",
        stderr: "inherit",
      });

      const child = fzfProc.spawn();
      const writer = child.stdin.getWriter();
      await writer.write(new TextEncoder().encode(fzfInput));
      await writer.close();
      const output = await child.output();
      const selected = new TextDecoder().decode(output.stdout).trim();

      if (!selected) {
        console.log("Cancelled.");
        Deno.exit(0);
      }

      const selectedUid = selected.split("\t")[0];
      event = getEventByUid(data, selectedUid);
      if (!event) {
        console.error(color.red("Error: Failed to find selected meeting"));
        Deno.exit(1);
      }
    } finally {
      try {
        Deno.removeSync(datefile);
      } catch { /* ignore */ }
    }
  }

  // Extract event details
  const start = toLocalDate(event.start);
  const end = toLocalDate(event.end);
  const localDate = formatDate(start);
  const startTime = formatTime(start);
  const endTime = formatTime(end);
  const invitees = getInvitees(event);
  const meetingType = detectMeetingType(event.title, invitees.length);
  const recurring = isRecurring(data, event);
  const series = recurring ? event.title : undefined;

  // Build file path
  const safeTitle = sanitizeFilename(event.title);
  const filename = `${safeTitle} - ${localDate}.md`;
  const filepath = join(MEETINGS_DIR, filename);

  // Check for existing note
  if (existsSync(filepath)) {
    if (jsonMode) {
      console.error(color.yellow(`Note already exists: ${filename}`));
      return;
    }
    console.error(color.yellow(`Note already exists: ${filename}`));
    if (Deno.stdin.isTerminal()) {
      const buf = new Uint8Array(10);
      Deno.stdout.writeSync(
        new TextEncoder().encode("Open existing note? [Y/n] "),
      );
      const n = Deno.stdin.readSync(buf);
      const answer = n
        ? new TextDecoder().decode(buf.subarray(0, n)).trim()
        : "Y";
      if (/^[Yy]?$/.test(answer)) {
        openInObsidian(filename);
      }
    }
    return;
  }

  // Ensure directory exists
  await Deno.mkdir(MEETINGS_DIR, { recursive: true });

  // Build note content
  const inviteeYaml = invitees.map((name) => `  - ${name}`).join("\n");
  const inviteeLinks = invitees.map((name) => `- [[${name}]]`).join("\n");

  let frontmatter = `---
tags:
  - meeting
date: ${localDate}
start-time: "${startTime}"
end-time: "${endTime}"`;

  if (series) frontmatter += `\nseries: "${series}"`;
  if (meetingType) frontmatter += `\nmeeting-type: ${meetingType}`;
  frontmatter += `\ninvitees:\n${inviteeYaml}`;
  if (event.organizer?.name && event.organizer.name !== SELF_NAME) {
    frontmatter += `\norganizer: ${event.organizer.name}`;
  }
  if (event.location) frontmatter += `\nlocation: "${event.location}"`;
  frontmatter += `\ncalendar: ${CALENDAR_FILTER}`;
  frontmatter += `\n---`;

  const noteContent = `${frontmatter}

# ${event.title}

## Attendees
${inviteeLinks}

## Notes

## Summary

## Action Items
- [ ] `;

  Deno.writeTextFileSync(filepath, noteContent);
  console.log(color.green(`Created: ${filename}`));
  openInObsidian(filename);
}

// --- Help ---

function showHelp(): void {
  const name = "mtg";
  console.log(`Usage: ${name} [command] [options]

Commands:
    list   (l)   List meetings for today (or specified date)
    create (c)   Create a meeting note
    help         Show this help

    If no command is given, interactively select a meeting and create a note.

Options:
    --date DATE   Target date in YYYY-MM-DD format (default: today)
    --json        Output as Alfred-compatible JSON (list command only)
    -q QUERY      Filter meetings by query (with --json)
    --uid UID     Specify meeting by calendar UID (create command)
    --help        Show this help

Examples:
    ${name}                           # Interactive: pick meeting & create note
    ${name} l                         # List today's meetings
    ${name} list --date 2026-03-01    # List meetings for a specific date
    ${name} list --json               # JSON output for Alfred
    ${name} list --json -q standup    # Alfred JSON filtered by query
    ${name} c                         # Interactively create a meeting note
    ${name} create --uid ABC-123      # Create note for a specific meeting UID`);
}

// --- Main ---

const args = Deno.args;
const command = args[0] ?? "";

// Internal subcommands (called by fzf)
if (command === "_preview") {
  cmdPreview(args[1]);
  Deno.exit(0);
}
if (command === "_fzf-data") {
  cmdFzfData(args[1]);
  Deno.exit(0);
}
if (command === "_fzf-nav") {
  cmdFzfNav(args[1], args[2]);
  Deno.exit(0);
}
if (command === "_fzf-header") {
  cmdFzfHeader(args[1]);
  Deno.exit(0);
}

// Parse remaining args after the command
const isCommand = ["l", "list", "c", "create", "help", "--help"].includes(
  command,
);
const restArgs = isCommand ? args.slice(1) : args;
const parsed = parseArgs(restArgs, {
  string: ["date", "q", "uid"],
  boolean: ["json", "help"],
  default: {
    date: formatDate(new Date()),
    json: false,
    q: "",
    uid: "",
  },
});

if (parsed.help || command === "help" || command === "--help") {
  showHelp();
  Deno.exit(0);
}

const targetDate = parsed.date as string;
const jsonMode = parsed.json as boolean;
const query = parsed.q as string;
const eventUid = parsed.uid as string;

switch (command) {
  case "l":
  case "list":
    cmdList(targetDate, jsonMode, query);
    break;
  case "c":
  case "create":
    await cmdCreate(targetDate, eventUid, jsonMode);
    break;
  default:
    // No command or unknown flag — default to create
    if (command && !command.startsWith("-")) {
      console.error(
        color.red(
          `Error: Unknown command: ${command}. Use 'mtg help' for usage.`,
        ),
      );
      Deno.exit(1);
    }
    await cmdCreate(targetDate, eventUid, jsonMode);
    break;
}
