#!/bin/bash
# ropen - remote open wrapper
# Sends open/vscode requests to the local open-agent via SSH-forwarded Unix socket.
# Falls back to native open if the agent socket isn't available.

set -euo pipefail

source "$(dirname "$0")/lib/open-agent.sh"

HOST_ALIAS="${OPEN_AGENT_HOST:-workmbp}"

usage() {
    cat <<'EOF'
Usage: ropen [options] <path|url>

Options:
  -a <app>    Open with specific application (e.g., -a "Marked 2")
  -v          Open as VS Code remote project (uses code --remote)
  -h          Show this help

Examples:
  ropen README.md                    # Open with default app on local machine
  ropen -a "Marked 2" doc.md         # Open with specific app
  ropen -v ~/projects/myapp          # Open folder in local VS Code via remote-ssh
  ropen https://github.com/foo/bar   # Open URL in local browser
EOF
    exit 0
}

die() { echo "${OA_SCRIPT_NAME}: $1" >&2; exit 1; }

# --- Parse arguments ---

APP=""
VSCODE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -a)
            [[ $# -lt 2 ]] && die "-a requires an application name"
            APP="$2"
            shift 2
            ;;
        -v) VSCODE=true; shift ;;
        -h|--help) usage ;;
        --) shift; break ;;
        -*) die "Unknown option: $1" ;;
        *) break ;;
    esac
done

[[ $# -eq 0 ]] && die "No path specified. See ropen -h for usage."
TARGET="$1"

# Detect URLs — open directly in local browser, no SSHFS needed
if [[ "$TARGET" =~ ^https?:// ]]; then
    IS_URL=true
else
    IS_URL=false
    # Resolve to absolute path (only for file paths)
    if [[ -e "$TARGET" ]]; then
        TARGET=$(realpath "$TARGET")
    elif [[ "$TARGET" != /* ]]; then
        TARGET="$(pwd)/$TARGET"
    fi
fi

# Detect VS Code by app name
if [[ "$APP" == *"Visual Studio Code"* ]] || [[ "$APP" == *"Code"* && "$APP" != *"Xcode"* ]]; then
    VSCODE=true
    APP=""  # VS Code uses --remote, not -a
fi

# --- Check socket availability ---

oa_init

if [[ ! -S "$OA_SOCK" ]]; then
    echo "${OA_SCRIPT_NAME}: agent socket not found at $OA_SOCK" >&2
    if command -v /usr/bin/open &>/dev/null; then
        echo "${OA_SCRIPT_NAME}: falling back to native open" >&2
        if [[ -n "$APP" ]]; then
            /usr/bin/open -a "$APP" "$TARGET"
        else
            /usr/bin/open "$TARGET"
        fi
        exit $?
    fi
    die "No agent socket and no native open available"
fi

# --- Build JSON message ---

ESCAPED_HOST=$(oa_json_escape "$HOST_ALIAS")

if $IS_URL; then
    ESCAPED_URL=$(oa_json_escape "$TARGET")
    MSG="{\"action\":\"open-url\",\"url\":${ESCAPED_URL}}"
elif $VSCODE; then
    ESCAPED_PATH=$(oa_json_escape "$TARGET")
    MSG="{\"action\":\"open-vscode\",\"host\":${ESCAPED_HOST},\"path\":${ESCAPED_PATH}}"
elif [[ -n "$APP" ]]; then
    ESCAPED_PATH=$(oa_json_escape "$TARGET")
    ESCAPED_HOME=$(oa_json_escape "$HOME")
    ESCAPED_APP=$(oa_json_escape "$APP")
    MSG="{\"action\":\"open\",\"host\":${ESCAPED_HOST},\"remoteHome\":${ESCAPED_HOME},\"path\":${ESCAPED_PATH},\"app\":${ESCAPED_APP}}"
else
    ESCAPED_PATH=$(oa_json_escape "$TARGET")
    ESCAPED_HOME=$(oa_json_escape "$HOME")
    MSG="{\"action\":\"open\",\"host\":${ESCAPED_HOST},\"remoteHome\":${ESCAPED_HOME},\"path\":${ESCAPED_PATH}}"
fi

# --- Send to agent ---

RESPONSE=$(oa_send "$MSG") || {
    echo "${OA_SCRIPT_NAME}: failed to connect to agent socket" >&2
    echo "${OA_SCRIPT_NAME}: the SSH tunnel may have died. Reconnect SSH to restore." >&2
    exit 1
}

# --- Handle response ---

if oa_check_response "$RESPONSE" 2>/dev/null; then
    LOCAL=$(oa_json_value "$RESPONSE" "localPath")
    if [[ -n "$LOCAL" ]]; then
        echo "Opened: $LOCAL"
    fi
    exit 0
else
    ERROR=$(oa_json_value "$RESPONSE" "error")
    die "${ERROR:-unknown error}"
fi
