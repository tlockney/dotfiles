#!/usr/bin/env bash

set -euo pipefail

# rproj - Unified Remote Project Tool
#
# Subcommands:
#   list     List remote projects (optionally as JSON for Alfred)
#   tmux     Open tmux session for a remote project
#   code     Open VS Code for a remote project
#   finder   Open project in local Finder via SSHFS (requires open-agent)
#   status   Show open-agent daemon status
#   setup    Print recommended SSH config for configured hosts
#   help     Show this help
#
# Run with no arguments for interactive mode.

SCRIPT_NAME="$(basename "$0")"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

source "$(dirname "${BASH_SOURCE[0]}")/lib/open-agent.sh"

# Config file locations
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rproj"
HOSTS_FILE="$CONFIG_DIR/hosts"
CONFIG_FILE="$CONFIG_DIR/config"

# Initialize open-agent with the local daemon socket path
oa_init "${HOME}/.local/share/open-agent/open-agent.sock"

# Colors (disabled in JSON mode)
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

# State
JSON_MODE=false
QUERY=""
PROJECT_PATH=""
SELECTED_HOST=""
HOST_FILTER=""

# Multi-host config: parallel arrays populated by load_hosts
HOST_ALIASES=()
HOST_DIRS=()
HOST_LABELS=()

# Logging (respects JSON mode)
info() {
    [[ "$JSON_MODE" == "true" ]] && return
    echo -e "${BLUE}$*${NC}"
}

success() {
    [[ "$JSON_MODE" == "true" ]] && return
    echo -e "${GREEN}$*${NC}"
}

warn() {
    [[ "$JSON_MODE" == "true" ]] && return
    echo -e "${YELLOW}$*${NC}" >&2
}

error() {
    if [[ "$JSON_MODE" == "true" ]]; then
        cat << EOF
{"items": [{
    "title": "Error",
    "subtitle": "$*",
    "valid": false,
    "icon": {"path": "error.png"}
}]}
EOF
        exit 0
    else
        echo -e "${RED}Error: $*${NC}" >&2
        exit 1
    fi
}

# Parent directory display label
parent_label() {
    echo "📂 $(basename "$1")"
}

# Strip tree-drawing prefix from fzf selection
strip_tree_prefix() {
    local s="$1"
    s="${s#  ├── }"
    s="${s#  └── }"
    echo "$s"
}

# Load multi-host configuration from hosts file or legacy config
load_hosts() {
    if [[ -f "$HOSTS_FILE" ]]; then
        while IFS='|' read -r alias dir label; do
            # Skip empty lines and comments
            [[ -z "$alias" || "$alias" == \#* ]] && continue
            # Trim whitespace
            alias="${alias## }" ; alias="${alias%% }"
            dir="${dir## }" ; dir="${dir%% }"
            label="${label## }" ; label="${label%% }"

            HOST_ALIASES+=("$alias")
            HOST_DIRS+=("$dir")
            HOST_LABELS+=("${label:-$alias}")
        done < "$HOSTS_FILE"
    elif [[ -f "$CONFIG_FILE" ]]; then
        # Legacy single-host fallback
        local RPROJ_HOST="workmbp"
        local RPROJ_DIR="/Users/thomas.lockney/src/metron"
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
        HOST_ALIASES+=("$RPROJ_HOST")
        HOST_DIRS+=("$RPROJ_DIR")
        HOST_LABELS+=("$RPROJ_HOST")
    else
        error "No hosts file ($HOSTS_FILE) or legacy config ($CONFIG_FILE) found"
    fi

    if [[ ${#HOST_ALIASES[@]} -eq 0 ]]; then
        error "No hosts configured"
    fi

    # Apply --host filter if set
    if [[ -n "$HOST_FILTER" ]]; then
        local filtered_aliases=() filtered_dirs=() filtered_labels=()
        for i in "${!HOST_ALIASES[@]}"; do
            if [[ "${HOST_ALIASES[$i]}" == "$HOST_FILTER" ]]; then
                filtered_aliases+=("${HOST_ALIASES[$i]}")
                filtered_dirs+=("${HOST_DIRS[$i]}")
                filtered_labels+=("${HOST_LABELS[$i]}")
            fi
        done
        if [[ ${#filtered_aliases[@]} -eq 0 ]]; then
            error "No entries found for host: $HOST_FILTER"
        fi
        HOST_ALIASES=("${filtered_aliases[@]}")
        HOST_DIRS=("${filtered_dirs[@]}")
        HOST_LABELS=("${filtered_labels[@]}")
    fi
}

# Discover projects across all configured hosts in parallel
# Output: lines of "host|base_dir|project_path|label"
discover_all_projects() {
    local tmpdir
    tmpdir=$(mktemp -d)

    # Launch SSH discovery in parallel for each host entry
    for i in "${!HOST_ALIASES[@]}"; do
        local host="${HOST_ALIASES[$i]}"
        local dir="${HOST_DIRS[$i]}"
        (
            ssh -o BatchMode=yes -o ConnectTimeout=3 "$host" \
                "find '$dir' -maxdepth 1 -mindepth 1 -type d -not -name '.*' | sort" \
                2>/dev/null > "$tmpdir/${i}" || true
        ) &
    done
    wait

    # Merge results
    for i in "${!HOST_ALIASES[@]}"; do
        local host="${HOST_ALIASES[$i]}"
        local dir="${HOST_DIRS[$i]}"
        local label="${HOST_LABELS[$i]}"

        # Parent directory entry
        echo "${host}|${dir}|${dir}|${label}"

        if [[ -s "$tmpdir/${i}" ]]; then
            while IFS= read -r line; do
                echo "${host}|${dir}|${line}|${label}"
            done < "$tmpdir/${i}"
        fi
    done

    rm -rf "$tmpdir"
}

# Build fzf display lines from discovery results
# Each line: "host|path\tLabel > display_text"
# fzf shows only the part after \t; selection includes hidden prefix
build_fzf_entries() {
    local entries="$1"
    local current_label="" child_count=0 child_idx=0
    local -a group_lines=() group_metas=()

    # Process entries group by group (grouped by label)
    while IFS='|' read -r host base_dir project_path label; do
        [[ -z "$host" ]] && continue

        if [[ "$label" != "$current_label" ]]; then
            # Flush previous group
            if [[ ${#group_lines[@]} -gt 0 ]]; then
                _flush_group "$current_label"
            fi
            current_label="$label"
            group_lines=()
            group_metas=()
        fi

        group_metas+=("${host}|${project_path}")
        if [[ "$project_path" == "$base_dir" ]]; then
            group_lines+=("__PARENT__|$(basename "$base_dir")")
        else
            group_lines+=("__CHILD__|$(basename "$project_path")")
        fi
    done <<< "$entries"

    # Flush last group
    if [[ ${#group_lines[@]} -gt 0 ]]; then
        _flush_group "$current_label"
    fi
}

_flush_group() {
    local label="$1"
    local children=0

    # Count children (non-parent entries)
    for line in "${group_lines[@]}"; do
        [[ "$line" == "__CHILD__|"* ]] && children=$((children + 1))
    done

    local child_idx=0
    for i in "${!group_lines[@]}"; do
        local type="${group_lines[$i]%%|*}"
        local name="${group_lines[$i]#*|}"
        local meta="${group_metas[$i]}"
        local display

        if [[ "$type" == "__PARENT__" ]]; then
            display="${label} > 📂 ${name}"
        else
            child_idx=$((child_idx + 1))
            if [[ $child_idx -eq $children ]]; then
                display="${label} >   └── ${name}"
            else
                display="${label} >   ├── ${name}"
            fi
        fi

        # Output: hidden metadata \t display string
        printf '%s\t%s\n' "$meta" "$display"
    done
}

# Interactive multi-host project selection with fzf
# Sets SELECTED_HOST and PROJECT_PATH globals
select_project_multi() {
    local entries="$1"
    local fzf_input
    fzf_input=$(build_fzf_entries "$entries")

    if [[ -z "$fzf_input" ]]; then
        error "No projects found on any configured host"
    fi

    local selected
    selected=$(echo "$fzf_input" | fzf \
        --height=60% \
        --layout=reverse \
        --border \
        --cycle \
        --delimiter=$'\t' \
        --with-nth=2 \
        --prompt="Select project: " \
        --header="Select a project to open" \
        --preview "'$SCRIPT_PATH' _preview_multi {1}")

    [[ -z "$selected" ]] && { echo "Cancelled."; exit 0; }

    # Extract host and path from the hidden metadata prefix
    local meta
    meta="${selected%%	*}"
    IFS='|' read -r SELECTED_HOST PROJECT_PATH <<< "$meta"
}

# Preview for multi-host selection (called by fzf --preview)
# Argument: "host|path"
cmd_preview_multi() {
    local meta="$1"
    local host path
    IFS='|' read -r host path <<< "$meta"

    ssh -o ConnectTimeout=2 "$host" "
        echo '$path'
        echo
        if git -C '$path' rev-parse --git-dir >/dev/null 2>&1; then
            echo 'Branch:'
            git -C '$path' branch --show-current 2>/dev/null
            echo
            echo 'Recent commits:'
            git -C '$path' log --oneline -5 2>/dev/null
            echo
        fi
        echo 'Contents:'
        ls -1 '$path' 2>/dev/null | head -20
    " 2>/dev/null
}

# Legacy single-host preview (called by fzf --preview)
cmd_preview() {
    local host="$1"
    local dir="$2"
    local item="$3"
    local path

    if [[ "$item" == 📂* ]]; then
        path="$dir"
    else
        item=$(strip_tree_prefix "$item")
        path="$dir/$item"
    fi

    ssh -o ConnectTimeout=2 "$host" "
        echo '$path'
        echo
        if git -C '$path' rev-parse --git-dir >/dev/null 2>&1; then
            echo 'Branch:'
            git -C '$path' branch --show-current 2>/dev/null
            echo
            echo 'Recent commits:'
            git -C '$path' log --oneline -5 2>/dev/null
            echo
        fi
        echo 'Contents:'
        ls -1 '$path' 2>/dev/null | head -20
    " 2>/dev/null
}

# Verify a specific project exists
verify_project() {
    local host="$1"
    local project_path="$2"

    if ! ssh -o BatchMode=yes "$host" "test -d '$project_path'" 2>/dev/null; then
        error "Project not found at $project_path on $host"
    fi
}

# Get project selection - interactive or by name
# For multi-host: if PROJECT_NAME is set, requires SELECTED_HOST to be set too
# Sets globals: SELECTED_HOST, PROJECT_PATH
get_project_selection() {
    local project_name="${1:-}"

    if [[ -n "$project_name" ]]; then
        # Direct project name requires a single host context
        if [[ -z "$SELECTED_HOST" ]]; then
            if [[ ${#HOST_ALIASES[@]} -eq 1 ]]; then
                SELECTED_HOST="${HOST_ALIASES[0]}"
            else
                error "Project name requires --host when multiple hosts are configured"
            fi
        fi
        # Find the matching host entry's directory
        local target_dir=""
        for i in "${!HOST_ALIASES[@]}"; do
            if [[ "${HOST_ALIASES[$i]}" == "$SELECTED_HOST" ]]; then
                target_dir="${HOST_DIRS[$i]}"
                break
            fi
        done
        [[ -z "$target_dir" ]] && error "Host $SELECTED_HOST not found in config"

        local plabel
        plabel=$(parent_label "$target_dir")
        if [[ "$project_name" == "$plabel" ]] || [[ "$project_name" == "$(basename "$target_dir")" ]]; then
            PROJECT_PATH="$target_dir"
        else
            PROJECT_PATH="$target_dir/$project_name"
            verify_project "$SELECTED_HOST" "$PROJECT_PATH"
        fi
        info "Using project: $project_name on $SELECTED_HOST"
    else
        info "Discovering projects..."
        local entries
        entries=$(discover_all_projects)

        if [[ -z "$entries" ]]; then
            error "No projects found"
        fi

        select_project_multi "$entries"
    fi
}

# Help message
show_help() {
    cat << EOF
Usage: $SCRIPT_NAME [command] [options] [project]

Commands:
    list    (l)   List remote projects
    tmux    (t)   Open tmux session for a project
    code    (c)   Open VS Code for a project
    finder  (f)   Open project in Finder via SSHFS (requires open-agent)
    status  (s)   Show open-agent daemon status
    setup         Print recommended SSH config for configured hosts
    open    (o)   Open from Alfred (host|path format)
    help          Show this help

    If no command is given, interactively select a project and action.

Options:
    -h, --host HOST   Filter to a specific host alias
    -p NAME           Project name (skip interactive selection)
    --json            Output as Alfred-compatible JSON (list command only)
    -q QUERY          Filter projects by query (list command with --json)
    --help            Show this help

Config:
    Multi-host: $HOSTS_FILE
    Legacy:     $CONFIG_FILE

Examples:
    $SCRIPT_NAME                         # Interactive: pick project & action
    $SCRIPT_NAME l                       # List all projects from all hosts
    $SCRIPT_NAME list -h workmbp         # List projects on workmbp only
    $SCRIPT_NAME list --json             # JSON output for Alfred
    $SCRIPT_NAME t                       # Interactive tmux selection
    $SCRIPT_NAME tmux -h workmbp proj    # Direct tmux on specific host
    $SCRIPT_NAME c                       # Interactive VS Code selection
    $SCRIPT_NAME f                       # Interactive: open project in Finder
    $SCRIPT_NAME setup                   # Print SSH config recommendations
    $SCRIPT_NAME s                       # Check open-agent status
EOF
    exit 0
}

# Parse common options for a subcommand
# Sets: HOST_FILTER, SELECTED_HOST, PROJECT_NAME, JSON_MODE, QUERY
parse_options() {
    PROJECT_NAME=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --help)
                show_help
                ;;
            -h|--host)
                if [[ $# -lt 2 ]]; then
                    error "Option $1 requires a host argument"
                fi
                HOST_FILTER="$2"
                SELECTED_HOST="$2"
                shift 2
                ;;
            -p)
                if [[ $# -lt 2 ]]; then
                    error "Option -p requires a project name"
                fi
                PROJECT_NAME="$2"
                shift 2
                ;;
            --json)
                JSON_MODE=true
                shift
                ;;
            -q)
                if [[ $# -lt 2 ]]; then
                    error "Option -q requires a query string"
                fi
                QUERY="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                # Positional argument is project name
                PROJECT_NAME="$1"
                shift
                ;;
        esac
    done
}

# Output projects as Alfred JSON (multi-host aware)
output_alfred_json() {
    local entries="$1"
    local query="$2"

    if [[ -z "$entries" ]]; then
        cat << EOF
{"items": [{
    "title": "No Projects Found",
    "subtitle": "No projects found on configured hosts",
    "valid": false,
    "icon": {"path": "error.png"}
}]}
EOF
        return
    fi

    echo '{"items": ['

    local first=true
    while IFS='|' read -r host base_dir project_path label; do
        [[ -z "$host" ]] && continue

        local project_name display_name subtitle
        project_name=$(basename "$project_path")

        if [[ "$project_path" == "$base_dir" ]]; then
            display_name="$(parent_label "$base_dir")"
        else
            display_name="$project_name"
        fi

        # Prefix with label if multiple hosts
        if [[ ${#HOST_ALIASES[@]} -gt 1 ]] || [[ $(printf '%s\n' "${HOST_ALIASES[@]}" | sort -u | wc -l) -gt 1 ]]; then
            subtitle="[$label] Open in VS Code: $project_path"
        else
            subtitle="Open in VS Code: $project_path"
        fi

        # Filter by query if provided (case-insensitive)
        if [[ -n "$query" ]] && [[ ! "${project_name,,}" =~ ${query,,} ]]; then
            continue
        fi

        if [[ "$first" != "true" ]]; then
            echo ","
        fi
        first=false

        cat << EOF
{
    "uid": "${host}_${project_name}",
    "title": "$display_name",
    "subtitle": "$subtitle",
    "arg": "$host|$project_path",
    "autocomplete": "$project_name",
    "icon": {"path": "vscode.png"}
}
EOF
    done <<< "$entries"

    echo ']}'
}

# Command: list
cmd_list() {
    parse_options "$@"
    load_hosts

    info "Discovering projects..."
    local entries
    entries=$(discover_all_projects)

    if [[ "$JSON_MODE" == "true" ]]; then
        output_alfred_json "$entries" "$QUERY"
    else
        if [[ -z "$entries" ]]; then
            warn "No projects found on any configured host"
            return
        fi

        local current_label=""
        while IFS='|' read -r host base_dir project_path label; do
            [[ -z "$host" ]] && continue

            # Print label header when it changes
            if [[ "$label" != "$current_label" ]]; then
                [[ -n "$current_label" ]] && echo ""
                echo -e "${GREEN}${label}${NC} ($host)"
                current_label="$label"
            fi

            if [[ "$project_path" == "$base_dir" ]]; then
                echo "  $(parent_label "$base_dir")"
            else
                echo "  $(basename "$project_path")"
            fi
        done <<< "$entries"
    fi
}

# Command: tmux
cmd_tmux() {
    parse_options "$@"
    load_hosts
    get_project_selection "$PROJECT_NAME"

    local session_name
    session_name=$(basename "$PROJECT_PATH")
    success "Opening tmux session '$session_name' at $PROJECT_PATH on $SELECTED_HOST..."

    ssh -A -t "$SELECTED_HOST" "cd '$PROJECT_PATH' && ~/bin/tc"
}

# Command: code
cmd_code() {
    parse_options "$@"
    load_hosts
    get_project_selection "$PROJECT_NAME"

    success "Opening $PROJECT_PATH in VS Code on $SELECTED_HOST..."
    code --remote "ssh-remote+$SELECTED_HOST" "$PROJECT_PATH"
}

# Command: default (interactive project + action selection)
cmd_default() {
    parse_options "$@"
    load_hosts
    get_project_selection "$PROJECT_NAME"

    local project_display
    project_display=$(basename "$PROJECT_PATH")

    local options="tmux\ncode"
    # Only show finder option if open-agent is running
    if [[ -S "$OA_SOCK" ]]; then
        options="$options\nfinder"
    fi

    local action
    action=$(printf "$options" | fzf \
        --height=30% \
        --layout=reverse \
        --border \
        --no-preview \
        --prompt="Action: " \
        --header="Open '$project_display' ($SELECTED_HOST) with:")

    [[ -z "$action" ]] && { echo "Cancelled."; exit 0; }

    case "$action" in
        tmux)
            local session_name
            session_name=$(basename "$PROJECT_PATH")
            success "Opening tmux session '$session_name' at $PROJECT_PATH..."
            ssh -A -t "$SELECTED_HOST" "cd '$PROJECT_PATH' && ~/bin/tc"
            ;;
        code)
            success "Opening $PROJECT_PATH in VS Code..."
            code --remote "ssh-remote+$SELECTED_HOST" "$PROJECT_PATH"
            ;;
        finder)
            _do_finder "$SELECTED_HOST" "$PROJECT_PATH"
            ;;
    esac
}

# --- open-agent helpers ---

# Wrapper that checks socket with rproj's error() (supports JSON mode)
_oa_checked_send() {
    if [[ ! -S "$OA_SOCK" ]]; then
        error "Agent socket not found at $OA_SOCK\n  Is open-agent running? Check: launchctl list | grep open-agent"
    fi
    oa_send "$1"
}

_oa_get_remote_home() {
    local host="$1"
    ssh -o BatchMode=yes -o ConnectTimeout=3 "$host" 'echo $HOME' 2>/dev/null
}

# Internal: perform finder open for a given host and project path
_do_finder() {
    local host="$1"
    local path="$2"

    info "Resolving remote home directory..."
    local remote_home
    remote_home=$(_oa_get_remote_home "$host") || {
        error "Could not determine remote home directory on $host"
    }

    local host_esc path_esc home_esc
    host_esc=$(oa_json_escape "$host")
    path_esc=$(oa_json_escape "$path")
    home_esc=$(oa_json_escape "$remote_home")

    local msg="{\"action\":\"open\",\"host\":${host_esc},\"remoteHome\":${home_esc},\"path\":${path_esc}}"
    success "Opening $path in Finder..."

    local response
    response=$(_oa_checked_send "$msg") || {
        error "Failed to communicate with open-agent"
    }

    if echo "$response" | grep -q '"ok":true'; then
        local local_path
        local_path=$(echo "$response" | grep -o '"localPath":"[^"]*"' | head -1 | sed 's/"localPath":"//' | sed 's/"$//')
        if [[ -n "$local_path" ]]; then
            success "Opened: $local_path"
        fi
    else
        local err_msg
        err_msg=$(echo "$response" | grep -o '"error":"[^"]*"' | head -1 | sed 's/"error":"//' | sed 's/"$//')
        error "${err_msg:-unknown error from agent}"
    fi
}

# Command: finder — open project in local Finder via SSHFS
cmd_finder() {
    parse_options "$@"
    load_hosts
    get_project_selection "$PROJECT_NAME"
    _do_finder "$SELECTED_HOST" "$PROJECT_PATH"
}

# Command: agent-status — check open-agent daemon status
cmd_agent_status() {
    if [[ ! -S "$OA_SOCK" ]]; then
        echo -e "${RED}Agent is not running${NC} (no socket at $OA_SOCK)"
        exit 1
    fi
    _oa_checked_send '{"action":"status"}'
}

# Command: open (for Alfred - opens with host|path format)
cmd_open() {
    if [[ $# -lt 1 ]]; then
        error "Usage: $SCRIPT_NAME open 'host|path'"
    fi

    local arg="$1"
    local host path
    IFS='|' read -r host path <<< "$arg"

    if [[ -z "$host" ]] || [[ -z "$path" ]]; then
        error "Invalid argument format. Expected 'host|path'"
    fi

    code --remote "ssh-remote+$host" "$path"
}

# Command: setup — print recommended SSH config for configured hosts
cmd_setup() {
    parse_options "$@"
    load_hosts

    local -a seen_hosts=()
    for i in "${!HOST_ALIASES[@]}"; do
        local host="${HOST_ALIASES[$i]}"
        # Skip duplicates
        local already_seen=false
        for seen in "${seen_hosts[@]+"${seen_hosts[@]}"}"; do
            if [[ "$seen" == "$host" ]]; then
                already_seen=true
                break
            fi
        done
        [[ "$already_seen" == "true" ]] && continue
        seen_hosts+=("$host")

        cat <<EOF

Host $host
    SetEnv OPEN_AGENT_HOST=$host
    RemoteForward /tmp/open-agent.sock ~/.local/share/open-agent/open-agent.sock
    StreamLocalBindUnlink yes
    ServerAliveInterval 30
    ServerAliveCountMax 3
EOF
    done

    echo ""
    echo "# Add the above to ~/.ssh/config (optional — SetEnv requires AcceptEnv on the remote sshd)."
    echo ""
    echo "# Alternatively, create an identity file on each remote host:"
    for host in "${seen_hosts[@]}"; do
        echo "#   ssh $host 'mkdir -p ~/.config/open-agent && echo $host > ~/.config/open-agent/identity'"
    done
    echo "#"
    echo "# The hook resolves host identity in this order:"
    echo "#   1. OPEN_AGENT_HOST env var (via SetEnv/AcceptEnv)"
    echo "#   2. ~/.config/open-agent/identity file"
    echo "#   3. \$(hostname -s) fallback"
}

# Main
main() {
    if [[ $# -lt 1 ]]; then
        cmd_default
        return
    fi

    local command="$1"
    shift

    case "$command" in
        l|list)
            cmd_list "$@"
            ;;
        t|tmux)
            cmd_tmux "$@"
            ;;
        c|code)
            cmd_code "$@"
            ;;
        f|finder)
            cmd_finder "$@"
            ;;
        s|status)
            cmd_agent_status "$@"
            ;;
        setup)
            cmd_setup "$@"
            ;;
        o|open)
            cmd_open "$@"
            ;;
        _preview)
            cmd_preview "$@"
            ;;
        _preview_multi)
            cmd_preview_multi "$@"
            ;;
        help|--help)
            show_help
            ;;
        -*)
            # Options without a subcommand -> interactive mode
            cmd_default "$command" "$@"
            ;;
        *)
            error "Unknown command: $command. Use '$SCRIPT_NAME help' for usage."
            ;;
    esac
}

main "$@"
